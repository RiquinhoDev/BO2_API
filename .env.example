# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Server Port (Railway will override this)
PORT=3001

# Environment
NODE_ENV=production

# JWT da API (obrigatorio, minimo 32 caracteres)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
# Opcional: apenas se a API antiga usar um segredo diferente
OLD_API_JWT_SECRET=change_me_to_the_old_api_secret_at_least_32_chars
# Rotas locais de teste/debug; o bootstrap recusa true em producao
ENABLE_DEBUG_ROUTES=false
# Origens CORS adicionais, separadas por virgula; os defaults sao preservados
ALLOWED_ORIGINS=https://front.example.com

# Financial Modeling Prep API (Clareza / Tremómetro)
FMP_API_KEY=your_fmp_api_key_here
CLAREZA_REFRESH_TOKEN=change_me_to_a_long_random_token

# Student OGI summary (frontend-safe flow uses signed token links)
STUDENT_ACCESS_JWT_SECRET=change_me_to_a_long_random_secret
STUDENT_SUMMARY_TOKEN=change_me_to_a_long_random_server_token

# Add other environment variables your app needs
# (Check your existing .env file for complete list)

# ─────────────────────────────────────────────────────────────
# Renovação OGI — sync BackOffice → ActiveCampaign (Fase B)
# Ver RENOVACAO_OGI_BO_PLAN.md (secções 11 e 13).
# AINDA NÃO IMPLEMENTADO — quando existir, a feature nasce DESLIGADA.
# Master kill switch: nada escreve na AC sem isto ser true.
RENEWAL_AC_SYNC_ENABLED=false
# Switches por operação (rollout gradual, um de cada vez):
RENEWAL_AC_WRITE_DATES=false
RENEWAL_AC_WRITE_TAGS=false
RENEWAL_AC_PROCESS_REFUNDS=false
# Config adicional da Fase B (defaults seguros se omitidos):
RENEWAL_AC_AUTO_EXECUTE=false
RENEWAL_AC_EXPIRY_FIELD_ID=332
RENEWAL_AC_MAX_CHANGES_PER_RUN=50

# ─────────────────────────────────────────────────────────────
# Renovação OGI — cargos Discord R.{Mês} + mensagens do bot
# Ver RENOVACAO_DISCORD_CARGOS_PLAN.md. Feature nasce DESLIGADA.
DISCORD_ROLES_SYNC_ENABLED=false
DISCORD_ROLES_AUTO_EXECUTE=false
DISCORD_MESSAGES_ENABLED=false
# Mensagens agendadas de renovação (dia 8 lembrete + dia 15 último aviso a @R.{mês anterior})
# Master switch; cada regra tem ainda o seu enabled na BD. Ver secção 12 do plano Discord.
DISCORD_SCHEDULED_MESSAGES_ENABLED=false
DISCORD_BOT_URL=https://api.serriquinho.com
DISCORD_ROLES_MAX_OPS_PER_RUN=100
DISCORD_MESSAGE_CHANNEL_ID=1182457352012697671
# BOT_SHARED_SECRET=  (Fase D5 — definir aqui E no serviço do bot para activar auth)
# Canais permitidos para comunicados do bot ("id:nome,id:nome").
# Adicionar o ID também em RENEWAL_MESSAGE_CHANNEL_IDS no serviço do bot.
DISCORD_MESSAGE_CHANNELS=1182457352012697671:anuncios-alunos
