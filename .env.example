# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Server Port (Railway will override this)
PORT=3001

# Environment
NODE_ENV=production

# Financial Modeling Prep API (Clareza / Tremómetro)
FMP_API_KEY=your_fmp_api_key_here
CLAREZA_REFRESH_TOKEN=change_me_to_a_long_random_token

# Add other environment variables your app needs
# (Check your existing .env file for complete list)
